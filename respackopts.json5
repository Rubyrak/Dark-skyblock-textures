{
    id: "darkModeSkyblock",
    version: 13,
    capabilities: ["FileFilter", "DirFilter"],
    conf: {
        islands:{
            enableEnd: true,
            enableRift: true,
            enableNether: false,
            enableWinter: false
        },
        zones:{
            enableGhosts: true,
            enableGlaciteTunnels: true,
            enableDungeons: false,
            enableKuudra: false
        },
        extras:{
            removeEntityFire: false,
            enableCustomFire: [
                "none",
                "vanilla",
                "gray",
                "desaturated"
            ],            
            enableCustomLava: [
                "none",
                "gray",
                "desaturated"
            ]
        }
    }
}
